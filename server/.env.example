# Copy this file to .env   (Windows: copy .env.example .env)

# Google Maps JavaScript API key (client fetches it from /api/config).
# Leave empty to run without maps — the app shows a placeholder instead.
MAPS_API_KEY=

# Ports
HTTP_PORT=8080
HTTPS_PORT=8443

# JWT signing secret (any random string is fine for a demo)
JWT_SECRET=yemberzal-demo-secret-change-me

# Default speed limit in km/h for violation detection (editable in the dashboard UI)
SPEED_LIMIT_KMH=40

# Seconds a bus must be stationary before we record a "stop"
STOP_MIN_SECONDS=45

# Seconds of continuous stop after which a "long stop" alert is raised
LONG_STOP_ALERT_SECONDS=120
